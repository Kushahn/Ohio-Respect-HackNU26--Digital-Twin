# =============================================================================
# Railway Digital Twin — Environment Variables
# =============================================================================
# Скопируйте этот файл в .env и заполните значения.
# НЕ коммитьте .env с реальными секретами!
# =============================================================================

# ---- База данных (PostgreSQL / TimescaleDB) ----
DATABASE_URL=postgresql+asyncpg://railway:railway_secret@localhost:5432/railway_twin
POSTGRES_USER=railway
POSTGRES_PASSWORD=railway_secret
POSTGRES_DB=railway_twin

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Backend (FastAPI) ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Секрет для подписи JWT-токенов (замените на случайную строку!)
JWT_SECRET=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ---- Docker Compose (опционально) ----
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- Frontend (Vite / React; для docker compose — подставляются в build args) ----
# С браузера на той же машине, где открыт UI, API и WS идут на localhost:8000
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/telemetry

# ---- Симулятор (локально: python -m app.simulator.simulator) ----
# В Docker Compose адрес задаётся в docker-compose.yml (WS_URL → backend)
WS_URL=ws://localhost:8000/ws/telemetry
SIMULATOR_MODE=NORMAL
LOCOMOTIVE_ID=KZ8A-Demo
