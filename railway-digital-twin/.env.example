# =============================================================================
# Railway Digital Twin — Environment Variables
# =============================================================================
# Скопируйте этот файл в .env и заполните значения.
# НЕ коммитьте .env с реальными секретами!
# =============================================================================

# ---- База данных (PostgreSQL / TimescaleDB) ----
DATABASE_URL=postgresql+asyncpg://railway:railway_secret@localhost:5432/railway_twin
POSTGRES_USER=railway
POSTGRES_PASSWORD=railway_secret
POSTGRES_DB=railway_twin

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Backend (FastAPI) ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Секрет для подписи JWT-токенов (замените на случайную строку!)
JWT_SECRET=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ---- Frontend (Vite / React) ----
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/telemetry

# ---- Симулятор ----
SIMULATOR_WS_URL=ws://localhost:8000/ws/telemetry/ingest
SIMULATOR_FREQUENCY_HZ=1
# Режим повышенной нагрузки: 0 = нормальный, 1 = highload (x10)
SIMULATOR_HIGHLOAD=0
# Тип локомотива: KZ8A | TE33A
SIMULATOR_LOCO_TYPE=KZ8A
